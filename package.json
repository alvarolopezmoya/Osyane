  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "cross-env ANALYZE=true vite build",
    "preview": "vite preview",
    "size": "npm run build && node scripts/size.mjs",
    "typecheck": "tsc --noEmit",
